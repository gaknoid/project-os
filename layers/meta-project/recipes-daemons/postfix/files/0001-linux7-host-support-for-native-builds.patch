From 71d8dca5ba223c970f8336f9f5f39ef9ac77fce5 Mon Sep 17 00:00:00 2001
From: GitHub Copilot <copilot@github.com>
Date: Sun, 14 Jun 2026 00:00:00 +0000
Subject: [PATCH] Add Linux 7 host support for native builds

Postfix 3.8.x only maps Linux releases up to 6.x in makedefs and only
enables Linux platform definitions for LINUX2..LINUX6 in sys_defs.h.

On hosts with kernel 7.x this causes postfix-native builds to fail with
"Unknown system type" or "unsupported platform" errors.

Teach makedefs to map Linux 7.x and enable the same Linux feature block
for LINUX7 in sys_defs.h.

Upstream-Status: Inappropriate [host compatibility in OE native builds]
Signed-off-by: GitHub Copilot <copilot@github.com>
---
 makedefs           | 2 +-
 src/util/sys_defs.h | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/makedefs b/makedefs
index 7e7f5f1..35ff90d 100755
--- a/makedefs
+++ b/makedefs
@@ -661,7 +661,7 @@ case "$SYSTEM.$RELEASE" in
		: ${SHLIB_ENV="LD_LIBRARY_PATH=`pwd`/lib"}
		: ${PLUGIN_LD="${CC-gcc} -shared"}
		;;
-    Linux.[3456].*)
+    Linux.[34567].*)
		SYSTYPE=LINUX$RELEASE_MAJOR
		case "$CCARGS" in
		 *-DNO_DB*) ;;
diff --git a/src/util/sys_defs.h b/src/util/sys_defs.h
index ead9a53..7cb528f 100644
--- a/src/util/sys_defs.h
+++ b/src/util/sys_defs.h
@@ -764,7 +764,7 @@ define HAVE_GLIBC_API_VERSION_SUPPORT(maj, min) \
  /*
   * LINUX.
   */
-#if defined(LINUX2) || defined(LINUX3) || defined(LINUX4) || defined(LINUX5) \
+#if defined(LINUX2) || defined(LINUX3) || defined(LINUX4) || defined(LINUX5) || defined(LINUX7) \
	|| defined(LINUX6)
 #define SUPPORTED
 #define UINT32_TYPE	unsigned int
--
2.43.0
